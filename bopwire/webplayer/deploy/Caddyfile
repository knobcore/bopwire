# Caddy config for the Bopwire web gateway.
# Caddy terminates TLS (auto Let's Encrypt) and reverse-proxies to the gateway,
# which listens on plain HTTP at 127.0.0.1:8090. CORS is emitted by the gateway,
# so Caddy just passes responses through.
#
# Prereq: an A record  api.bopwire.com -> <your-vps-ip>  (Namecheap), and ports
# 80 + 443 open on the VPS (Caddy needs 80/443 reachable to fetch the cert).

api.bopwire.com {
	encode zstd gzip

	# Single reverse_proxy (the first handler is terminal — a second bare
	# reverse_proxy below was dead config). Audio responses can be large, so
	# stream unbuffered. Reset X-Forwarded-For to the real peer so a client
	# cannot spoof the gateway's per-IP rate-limit key (the gateway also takes
	# the last XFF hop defensively).
	reverse_proxy 127.0.0.1:8090 {
		flush_interval -1
		header_up X-Forwarded-For {remote_host}
	}

	log {
		output file /var/log/caddy/bopwire-api.log
		format console
	}
}
