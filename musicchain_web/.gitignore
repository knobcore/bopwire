# CMake / Emscripten build tree — wiped and re-created by build.sh.
build/

# Vite production bundle — `npm run build` output.
dist/

# Node deps.
node_modules/

# WASM artifacts — regenerated from native/ + ../musicchain/ +
# ../chromaprint-1.5.1/ + librats / chain core by build.sh. Never
# check these in: they're large, platform-noisy in diffs, and trivially
# reproducible from source.
wasm/wallet.*
wasm/chromaprint.*
wasm/rats.*
wasm/chain.*

# Local env overrides for the dev server (VITE_HOME_WS, etc.).
.env
.env.local
.env.*.local

# Editor / OS scratch.
.vscode/
.idea/
.DS_Store
Thumbs.db

# TypeScript incremental cache.
*.tsbuildinfo
